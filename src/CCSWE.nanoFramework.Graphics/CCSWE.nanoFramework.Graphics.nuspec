<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>CCSWE.nanoFramework.Graphics</id>
    <title>CCSWE.nanoFramework.Graphics</title>
    <version>1.0</version>
    <authors>Cory Charlton</authors>
    <owners>Cory Charlton,CCSWE</owners>
    <license type="file">LICENSE.md</license>
    <projectUrl>https://github.com/CCSWE-nanoFramework/CCSWE.nanoFramework</projectUrl>
    <icon>images\ccswe-logo.png</icon>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <readme>README.md</readme>
    <developmentDependency>false</developmentDependency>
    <description>Color conversion and utility helpers for nanoFramework.</description>
    <repository type="git" url="https://github.com/CCSWE-nanoFramework/CCSWE.nanoFramework" commit="$commit$" />
    <copyright>Copyright (c) Cory Charlton</copyright>
    <tags>nanoFramework C# csharp netmf netnf ccswe graphics color</tags>
    <dependencies>
      <dependency id="CCSWE.nanoFramework.Math" version="$version$" />
      <dependency id="nanoFramework.CoreLibrary" version="1.17.11" />
      <dependency id="nanoFramework.Graphics.Core" version="1.2.45" />
      <dependency id="nanoFramework.System.Math" version="1.5.116" />
    </dependencies>
  </metadata>
  <files>
    <file src="bin\Release\CCSWE.nanoFramework.Graphics.*" target="lib\netnano1.0" />
    <file src="..\..\ccswe-logo.png" target="images" />
    <file src="..\..\LICENSE.md" target="" />
    <file src="README.md" target="" />
  </files>
</package>
